# =============================================================
# Copy this file to .env and fill in your real values:
#   cp .env.example .env
# Then edit .env with your credentials.
# .env is gitignored and never committed.
# =============================================================

# --- Telegram credentials (required) ---
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Your chat ID from https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=

# --- Runtime options (optional; defaults shown) ---

# RSI look-back period.
RSI_LENGTH=14

# Oversold line: alert when RSI drops under this.
RSI_THRESHOLD=30

# Overbought line: alert when RSI rises over this.
RSI_HIGH_THRESHOLD=70

# Candle size the RSI is computed on: 15m | 1h | 4h | 1d ...
MONITOR_TIMEFRAME=1d

# Hour (UTC, 0-23) to send the once-a-day digest.
DIGEST_HOUR_UTC=8

# How often (seconds) to scan all symbols. 600 = 10 min.
MONITOR_INTERVAL=600

# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
